# Server configuration
PORT=5000
FLASK_ENV=development
SECRET_KEY=super-secret-key-for-local-tokens

# Firebase Service Account (For Backend Firestore & Admin SDK)
# If these are empty, backend runs in local SQLite mode
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Firebase Client SDK Credentials (Frontend uses these)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# External APIs
GROQ_API_KEY=
CARBON_INTERFACE_API_KEY=

# Endpoint Base URL for Frontend
VITE_API_BASE_URL=http://localhost:5000
